# ===================== 通用忽略规则 =====================
# 系统文件（Windows）
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk
*.tmp
*.bak
*.swp
.DS_Store  # Mac系统文件（跨平台兼容）

# 编辑器/IDE配置
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-*

# ===================== Node.js 项目忽略规则 =====================
# 依赖包（核心，避免提交node_modules）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json.bak
yarn.lock

# 环境变量配置
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ===================== Electron 项目忽略规则 =====================
dist/

# Electron 缓存/临时文件
electron-builder-cache/
electron-builder-effective-config.yaml

# 日志文件
*.log

内部文档/

